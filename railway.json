{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend/RenovoWorkshop.Api && dotnet restore && dotnet publish -c Release -o ../../publish"
  },
  "deploy": {
    "startCommand": "cd backend/publish && dotnet RenovoWorkshop.Api.dll",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
